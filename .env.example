# Single sensor
AIRGRADIENT_HOSTS=192.168.1.100

# Multiple sensors (comma-separated)
# AIRGRADIENT_HOSTS=192.168.1.100,192.168.1.101,192.168.1.102

# IQAir API key for outdoor air quality (optional, free at https://www.iqair.com/dashboard/api)
# IQAIR_API_KEY=your-api-key-here

# Server-side outdoor location (optional, locks the outdoor section to this city)
# OUTDOOR_CITY=London
# OUTDOOR_STATE=England
# OUTDOOR_COUNTRY=United Kingdom

# PirateWeather API key for weather data (optional, free at https://pirate-weather.apiable.io/)
# PIRATE_WEATHER_KEY=your-pirate-weather-key-here

# Weather location coordinates (optional, auto-detected from outdoor city if not set)
# WEATHER_LAT=
# WEATHER_LON=
